   "source": [
    "## Step 1: Configure API Keys\n1. Go to **Add-ons -> Secrets** in the top menu of your Kaggle notebook.\n2. Add `CDS_URL` with value `https://cds.climate.copernicus.eu/api`\n3. Add `CDS_KEY` with your token (e.g. `f1eef164-...`)\n4. Add `OPENTOPOGRAPHY_KEY` with your OpenTopography token"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from kaggle_secrets import UserSecretsClient\nimport os\ntry:\n    user_secrets = UserSecretsClient()\n    # Copernicus\n    cds_url = user_secrets.get_secret(\"CDS_URL\")\n    cds_key = user_secrets.get_secret(\"CDS_KEY\")\n    rc_path = os.path.expanduser('~/.cdsapirc')\n    with open(rc_path, 'w') as f:\n        f.write(f\"url: {cds_url}\\n",
    "key: {cds_key}\\n"
   ]
  },
